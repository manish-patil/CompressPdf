<Window x:Class="PDFCompress.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PDFCompress"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:CompressToColorConverter x:Key="CompressToColorConverter"/>
        <local:CompressToColorConverter x:Key="IsCompressedConverter"/>
    </Window.Resources>
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="300">
            <StackPanel Orientation="Vertical">
                <TextBlock FontSize="50" FontWeight="Bold" Foreground="Navy" HorizontalAlignment="Center" VerticalAlignment="Center">PDF Compressor</TextBlock>
                <Button Name="btnSelectFile" 
                        IsEnabled="{Binding !IsCompressing}"
                        FontSize="30" 
                        Click="btnSelectFile_Click" Background="Transparent" Foreground="Navy" 
                        Content="Select .pdf File to Compress" 
                        HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40 40 40 30">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="Navy" BorderThickness="2" CornerRadius="20" Padding="20 10 10 10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Name="lblSelectedFileName" 
                           Text="{Binding FileNameToCompress, Mode=OneWay}"
                           Visibility="{Binding FileSelectedToCompress, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                           FontSize="30" Foreground="Navy" HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                <Button Name="btnCompressFile" 
                        Visibility="{Binding FileSelectedToCompress, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                        IsEnabled="{Binding !IsCompressing}"
                        Click="btnCompressFile_Click" FontSize="30" Foreground="Navy" Background="AliceBlue" Content="Compress File" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 30 0 0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="Blue" BorderThickness="2" CornerRadius="20" Padding="20 10 10 10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!--<CheckBox Name="chkReplaceOriginalFile" Margin="0 10" FontSize="30" Foreground="Navy" HorizontalAlignment="Center" VerticalAlignment="Center" Content="Replace Original File"/>-->
                        <!--Visibility="{Binding IsCompressed, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"-->
                <TextBlock Name="lblStatus" 
                        Visibility="{Binding IsCompressed, Converter={StaticResource IsCompressedConverter}}"
                        Text="{Binding CompressionStatusMessage, Mode=OneWay}"
                        FontSize="30" 
                        Foreground="{Binding IsCompressed, Converter={StaticResource CompressToColorConverter}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"></TextBlock>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
